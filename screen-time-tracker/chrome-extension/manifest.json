{
  "manifest_version": 3,
  "name": "Burnout Tracker - Tab Monitor",
  "version": "1.0",
  "description": "Sends open tab data to the Burnout Tracker backend to analyze productive vs unproductive browsing.",
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["https://burnout-n9p9.onrender.com/*", "http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Burnout Tracker"
  }
}
